# ════════════════════════════════════════════════════════════
# OpenQHSE Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ════════════════════════════════════════════════════════════

# ── General ─────────────────────────────────────────────────
APP_NAME=OpenQHSE
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
IS_PRODUCTION=false

# ── Database (PostgreSQL 17) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openqhse:password@localhost:5432/openqhse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=openqhse
POSTGRES_PASSWORD=openqhse_dev_2026
POSTGRES_DB=openqhse

# ── Redis 7.4 ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDBEAT_REDIS_URL=redis://localhost:6379/3
REDIS_PASSWORD=

# ── Auth — SOLO httpOnly cookies, NUNCA localStorage ─────────
# JWT para FastAPI backend
API_SECRET_KEY=change-me-in-production-min-32-chars-required
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30
API_REFRESH_TOKEN_EXPIRE_DAYS=7
# NextAuth.js v5 — gestiona sesión browser
NEXTAUTH_SECRET=change-me-in-production-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Storage (MinIO dev / S3 prod) ───────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=openqhse
# AWS S3 (producción)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=openqhse-prod

# ── AI — Ollama 0.5.4 ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openqhse.io
SMTP_TLS=true

# ── Notificaciones Multicanal ────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_WEBHOOK=
TEAMS_WEBHOOK=
EXPO_ACCESS_TOKEN=

# ── Integraciones ERP / BI ───────────────────────────────────
SAP_API_URL=
SAP_API_KEY=
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# ── Monitoreo ────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Grafana / Prometheus ─────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
